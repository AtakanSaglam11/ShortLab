# =========================================
# Instagram Analytics — environment example
# Copy to .env.local for local dev.
# =========================================

# Data source: "mock" (factice, par défaut) ou "ig" (Instagram Graph API)
DATA_SOURCE=mock

# --- Instagram Graph API ---
# Ignoré tant que DATA_SOURCE=mock.
# Voir README.md > "Instagram Graph API setup" pour générer le token long-lived (60 jours).
IG_ACCESS_TOKEN=
IG_USER_ID=

# --- Base de données ---
# SQLite en local. En prod, remplace par une URL Postgres
# et change le provider dans prisma/schema.prisma.
DATABASE_URL="file:./prisma/dev.db"

# --- Sécurité cron ---
# Token requis pour appeler /api/cron/daily. Génère un truc long et random.
CRON_SECRET=change-me-to-a-long-random-string

# --- App ---
# URL publique de l'app (utilisée pour les liens absolus, OG, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# --- Auth basique (prod uniquement) ---
# Si défini, le middleware exige une basic-auth admin:<password>.
# Laisser vide en local.
AUTH_PASSWORD=
